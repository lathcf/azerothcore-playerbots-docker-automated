# Copied to azerothcore-wotlk/.env by setup.sh. Edit values as desired.
# These feed the fork's docker-compose.yml.

# --- Database ---
# CHANGE THIS before exposing the server to anything but your trusted LAN. setup.sh REFUSES to
# run with PUBLIC_REALM_ADDRESS set while this is still the default. Use a long, unique value.
DOCKER_DB_ROOT_PASSWORD=changeme_db_password
# --- Published ports (host:container). Defaults match WoW 3.3.5a clients. ---
# Only AUTH (3724) and WORLD (8085) are ever published to the network. setup.sh's generated
# docker-compose.override.yml binds MySQL to 127.0.0.1 only and DROPS the SOAP port entirely,
# so DOCKER_SOAP_EXTERNAL_PORT / DOCKER_DB_EXTERNAL_PORT are effectively local-only now.
# NEVER port-forward 3306 (MySQL) or 7878 (SOAP) on your router.
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_SOAP_EXTERNAL_PORT=7878
DOCKER_DB_EXTERNAL_PORT=3306

# --- External access (let a friend play from outside your LAN) ---
# Leave BLANK for a LAN-only server (the default — realmlist points at your private IP).
# To expose: set this to your WAN public IP, or a DDNS hostname if your home IP is dynamic
# (resolved by the authserver at startup, so restart the stack after the IP behind it changes).
# Remote clients are handed this address; LAN clients still get the private IP automatically.
# Then on your Omada firewall: port-forward ONLY TCP 3724 + 8085 to this server, with an ACL
# restricting the source to your friend's static IP. See README "Exposing to a friend".
PUBLIC_REALM_ADDRESS=

# --- Realm LAN IP override ---
# Blank = autodetect from the default route (correct on a normal Linux host). On Windows/WSL2,
# set this to your WINDOWS HOST's LAN IP — WSL's autodetect returns the VM's internal NAT
# address (172.x), which LAN clients can't reach. The Windows installer
# (windows/Setup-AzerothCore.ps1) fills this in for you automatically.
LAN_IP=

# --- Container user (set automatically by setup.sh to the server user's id) ---
# Must match the host user so bind-mounted config/logs are writable.
DOCKER_USER_ID=1000
DOCKER_GROUP_ID=1000

# --- Image tag for the acore base images ---
DOCKER_IMAGE_TAG=master

# --- Server timezone ---
# IANA timezone name (e.g. America/Chicago, Europe/London) applied to the worldserver,
# db, and db-import containers via the TZ env var. This sets the in-game "server time"
# clock and all log timestamps; it also shifts when daily/weekly resets, Wintergrasp,
# and AHBot cycles land. Use an IANA name, NOT an abbreviation like "CST". Blank/unset
# falls back to Etc/UTC. NOTE: the nightly backup cron runs on the HOST clock, not this —
# set the host too with: sudo timedatectl set-timezone America/Chicago
SERVER_TZ=America/Chicago

# --- Bot population ---
# Total roaming bots kept online (spread across level brackets & both factions).
# ~MAX_RANDOM_BOTS / 20 bots per faction per level bracket. Higher = denser world,
# more CPU/RAM. 2000 is demanding — see README before pushing past it.
MAX_RANDOM_BOTS=500

# --- Performance / hardware tuning (worldserver + playerbots threads) ---
# Throughput knobs. Defaults suit a mid-range host (roughly 4-8 cores) with a moderate-to-high
# bot count; scale them to your CPU and how many bots you run. Changing these just needs a
# re-run of setup.sh + a worldserver restart (no rebuild).
MAP_UPDATE_THREADS=6              # worldserver map-update threads — the biggest CPU lever with many
                                  # bots. The wiki caps its advice around 6 even on big boxes
                                  # (diminishing returns vs. other threads competing for cores).
PLAYERBOTS_DB_WORKER_THREADS=1   # bot-DB worker threads (wiki-recommended split)
PLAYERBOTS_DB_SYNCH_THREADS=2    # bot-DB synch threads
BOT_ACTIVE_ALONE=10              # % of bots running full AI when no real player is near (lower =
                                  # cheaper; raise for a livelier empty world if you have CPU spare)
BOT_ACTIVE_ALONE_SMART_SCALE=1   # auto-throttle BotActiveAlone when the server tick gets heavy (1=on)

# --- Database performance (MySQL/MariaDB innodb tuning) ---
# Written to config/mysql-tuning.cnf and loaded LAST so it overrides the image defaults. Defaults
# assume the DB SHARES RAM with a bot-heavy worldserver, so the buffer pool is sized to the working
# set + headroom rather than the usual "50% of RAM" rule (which assumes a DEDICATED DB host and can
# OOM a shared box). Scale to your RAM (buffer pool) and disk speed (io capacity).
DB_BUFFER_POOL_SIZE=8G           # InnoDB buffer pool — the main RAM lever. On a shared box keep
                                  # well under total RAM; on a dedicated DB host it can go higher.
DB_BUFFER_POOL_INSTANCES=8       # split the pool into N instances (rule of thumb: keep each >=1GB)
DB_IO_CAPACITY=500               # baseline IOPS budget — raise for SSD/NVMe (e.g. 2000), lower for HDD
DB_IO_CAPACITY_MAX=2500          # burst IOPS ceiling — raise for SSD/NVMe

# --- Quality-of-life tweaks ---
# Free Dual Talent Specialization: removes the 1000g trainer cost (still requires
# level 40 + a class trainer). 1 = free, 0 = retail 1000g cost. Re-applied to the
# world DB on every setup run, so it survives rebuilds and a full world-DB re-import.
FREE_DUAL_SPEC=1

# How much bots talk in chat. Tunes the base playerbots canned channel broadcasts
# (loot/kill/quest spam in World/General/Trade/LFG).
#   off    = no ambient or bot-to-bot chatter; bots still reply when YOU talk to them
#   low    = some flavor, ~90% less channel spam
#   mild   = a notch above low; a bit more ambient + bot-to-bot, still far below normal (default)
#   normal = stock module defaults (very chatty)
# Bots always answer a real player regardless of this setting.
BOT_CHATTER=mild

# --- Backups (nightly mysqldump cron, installed by setup.sh) ---
# setup.sh installs a cron that runs ./backup.sh (gzipped dump of all DBs to ./backups/).
# BACKUP_CRON=0 skips installing the cron (run ./backup.sh manually instead).
# BACKUP_SCHEDULE is standard cron syntax — MUST be quoted (contains spaces).
# BACKUP_KEEP is how many timestamped dumps to retain.
# NOTE: the cron fires on the HOST clock, not SERVER_TZ.
BACKUP_CRON=1
BACKUP_SCHEDULE="0 4 * * *"
BACKUP_KEEP=14

# --- Auction house economy (mod-ah-bot-plus) ---
# GUID(s) of a dedicated, NORMAL (non-playerbot) character the AH bot operates as.
# Leave blank to keep AHBot off. Comma-separate for multiple (e.g. 3,4).
# Find a GUID after creating the character:
#   SELECT guid,name FROM acore_characters.characters WHERE name='YourAHChar';
AHBOT_GUIDS=

# --- Registration website (ac-webreg) ---
# A small Go service for friends to register/login/change-password, plus a client
# download. Runs as another container in this stack, published on the LAN only. For LAN use
# browse to http://<this-host-LAN-ip>:<WEBREG_LAN_PORT>; to expose it externally put it behind
# a reverse proxy or tunnel (e.g. Cloudflare Tunnel, nginx+TLS) rather than WAN-forwarding the
# raw port. Leave WEBREG_ADMIN_PASS blank to keep the site OFF (setup.sh skips the service).
WEBREG_ADMIN_PASS=
WEBREG_ADMIN_USER=admin
# Display name shown on the registration site's landing page (browser title + heading).
# Quote it if it contains spaces — this file is also sourced by setup.sh/backup.sh.
WEBREG_SITE_NAME="WoW Server"
# Host LAN bind port the service listens on (and that your reverse proxy/tunnel points at).
WEBREG_LAN_PORT=8090
# Path on THIS host to the client zip you prepared (bind-mounted read-only into the
# container). Leave blank to hide the download button.
CLIENT_ZIP_PATH=./client-dist/wow-335a.zip
# Quote any value containing spaces — this file is also sourced by setup.sh/backup.sh.
CLIENT_ZIP_LABEL="Download WoW 3.3.5a client + addons"
# The admin account list hides playerbot accounts whose username starts with this
# prefix. Must match playerbots' AiPlayerbot.RandomBotAccountPrefix (default rndbot).
WEBREG_BOT_PREFIX=rndbot
# Autogenerated by setup.sh if left blank — no need to set these by hand.
WEBREG_SESSION_SECRET=
WEBREG_DB_PASS=

# ── Ollama host (shared by AI bot chat + lore sidecar) ───────────────────────
# IP or hostname of the machine running Ollama. Used to build CHATTER_URL and reached
# directly by the lore sidecar. Default host.docker.internal = this Docker host itself;
# set it to your GPU box's LAN IP if Ollama runs on a different machine. Only matters when
# CHATTER_ENABLE=1 or LORE_ENABLE=1 — and remember to `ollama pull` your model first.
OLLAMA_IP=host.docker.internal

# ── AI bot chat (mod-playerbot-chatter) ──────────────────────────────────────
# Two Ollama-driven layers: REACTIVE replies to player whispers / party-raid /
# proximity-say, and AMBIENT self-initiated chatter in General / party-raid / guild
# (replaces playerbots' canned broadcasts). Does NOT touch playerbot/MultiBot commands.
# When enabled, playerbots' RandomBotTalk + EnableBroadcasts + RandomBotSayWithoutMaster
# are pinned OFF so this mod owns the entire bot voice.
# Master switch — turns on BOTH layers (ambient follows this unless CHATTER_AMBIENT_ENABLE is set).
CHATTER_ENABLE=0
# Ollama endpoint. Defaults to http://${OLLAMA_IP}:11434/api/generate if OLLAMA_IP is set.
#CHATTER_URL=http://10.0.0.5:11434/api/generate
# Pick a model your Ollama GPU can run. llama3.1:8b (~5.5GB at Q4) gives solid WoW knowledge +
# tool calling and runs well on an 8GB card; ~4B models know the game noticeably less well.
CHATTER_MODEL=llama3.1:8b
# CHATTER_THINK only matters for reasoning models (e.g. qwen3): 0 sends think=false. Harmless
# for llama3.1.
CHATTER_THINK=0
# Parallel Ollama requests. On an 8GB GPU with an 8B model, 2-3 is safe; lower if VRAM is tight.
CHATTER_MAX_CONCURRENT=3
# Fan-out: ambient say and un-named group chat -> random N nearby/grouped bots, chance-rolled.
CHATTER_SAY_RANGE=40
CHATTER_SAY_MAX_BOTS=2
CHATTER_SAY_CHANCE=35
CHATTER_GROUP_MAX_BOTS=2
CHATTER_GROUP_CHANCE=50
# Force at least one party/raid bot to answer when you address the group (1=on).
CHATTER_GROUP_GUARANTEE_ONE=1
CHATTER_WHISPER_CHANCE=100
CHATTER_HISTORY_LEN=10
CHATTER_REPLY_MAXLEN=200
# Override the bot persona / system prompt (shared by both layers). Leave unset to use the
# built-in WotLK-grounded "real person playing the game" prompt. Must be a single quoted line.
#CHATTER_SYSTEM_PROMPT="You're a real person playing WoW 3.3.5a, chatting in-game. Keep it short and casual."
#
# ── Ambient (self-initiated) chatter ─────────────────────────────────────────
# Bots open and carry conversations on their own in any channel that holds a real
# player (empty channels cost zero GPU). All optional — values shown are the built-in
# defaults; uncomment to tune. Ambient turns on automatically with CHATTER_ENABLE=1.
#CHATTER_AMBIENT_ENABLE=1            # defaults to CHATTER_ENABLE
#CHATTER_AMBIENT_GENERAL=1           # speak in a zone's General channel
#CHATTER_AMBIENT_GROUP=1             # speak in party/raid
#CHATTER_AMBIENT_GUILD=1             # speak in guild chat
# Cadence (seconds): slow "seed" opens a topic, fast "follow-up" carries a burst.
#CHATTER_AMBIENT_SEED_MIN=60
#CHATTER_AMBIENT_SEED_MAX=90
#CHATTER_AMBIENT_FOLLOWUP_MIN=4
#CHATTER_AMBIENT_FOLLOWUP_MAX=9
#CHATTER_AMBIENT_ACTIVE_WINDOW=75    # a context stays "active" this long after the last line
# Bot-to-bot brakes: cap consecutive bot lines, then cool the thread down.
#CHATTER_AMBIENT_BOT_STREAK_MAX=4
#CHATTER_AMBIENT_COOLDOWN=75         # thread cooldown (s) after hitting the streak cap
#CHATTER_AMBIENT_PER_BOT_COOLDOWN=120 # min gap (s) between one bot's ambient lines
#CHATTER_AMBIENT_MAX_PER_MIN=25      # global ambient messages/min ceiling (raise=livelier, lower if GPU-bound)
#CHATTER_AMBIENT_BUFFER_LEN=8        # recent lines kept per context for "react" mode
# Content mix (relative weights): React weighted high so bots answer each other once a
# channel is active; generic openers when it's quiet.
#CHATTER_AMBIENT_W_GENERIC=35
#CHATTER_AMBIENT_W_REACT=45
#CHATTER_AMBIENT_W_FLAVOR=12
#CHATTER_AMBIENT_W_EVENT=8           # ding / quest / boss-kill riffs (loot riff was removed)

# ── Lore sidecar (mod-playerbot-chatter Tier-2: factual Q&A) ──────────────────
# When 1, the ac-lore Python sidecar is built/started and the worldserver routes
# whispered factual questions ("where's the nearest trainer?") to it. Answers come
# from real game data; on any miss the bot falls back to a normal reply. Builds on
# the reactive chatter layer, so it also needs CHATTER_ENABLE=1 (above) and OLLAMA_IP
# set (the sidecar calls the same Ollama as the chatter module).
LORE_ENABLE=0
LORE_PORT=8091
LORE_MODEL=llama3.1:8b
# LORE_TIMEOUT = worldserver's total wait for the sidecar (covers both model calls);
# LORE_GEN_TIMEOUT = the sidecar's per-Ollama-call ceiling. Raise both if the GPU is slow
LORE_TIMEOUT=60
LORE_GEN_TIMEOUT=60
# Verbose request/reply logging from the sidecar (1=on).
LORE_DEBUG=0
# Autogenerated by setup.sh if left blank (read-only 'lore' MySQL user) — no need to set.
LORE_DB_PASS=
